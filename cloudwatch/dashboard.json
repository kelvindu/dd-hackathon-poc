{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Error Rate (errors / requests)",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            {
              "expression": "errors / requests * 100",
              "label": "Error Rate (%)",
              "id": "error_rate"
            }
          ],
          [
            "POC/FaultyWorkload",
            "error_count_total",
            {
              "id": "errors",
              "visible": false,
              "stat": "Sum"
            }
          ],
          [
            "POC/FaultyWorkload",
            "request_count_total",
            {
              "id": "requests",
              "visible": false,
              "stat": "Sum"
            }
          ]
        ],
        "period": 60,
        "stat": "Sum",
        "region": "${AWS::Region}",
        "yAxis": {
          "left": {
            "min": 0,
            "label": "Error Rate (%)"
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Warning Count",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "POC/FaultyWorkload",
            "warning_count_total",
            {
              "stat": "Sum",
              "label": "Warnings",
              "color": "#ff7f0e"
            }
          ]
        ],
        "period": 60,
        "region": "${AWS::Region}",
        "yAxis": {
          "left": {
            "min": 0,
            "label": "Count"
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Latency P50 and P99",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "POC/FaultyWorkload",
            "latency_ms",
            {
              "stat": "p50",
              "label": "Latency P50 (ms)",
              "color": "#1f77b4"
            }
          ],
          [
            "POC/FaultyWorkload",
            "latency_ms",
            {
              "stat": "p99",
              "label": "Latency P99 (ms)",
              "color": "#d62728"
            }
          ]
        ],
        "period": 60,
        "region": "${AWS::Region}",
        "yAxis": {
          "left": {
            "min": 0,
            "label": "Milliseconds"
          }
        }
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Pod Restart Count",
        "view": "timeSeries",
        "stacked": false,
        "metrics": [
          [
            "POC/FaultyWorkload",
            "restart_count_total",
            {
              "stat": "Sum",
              "label": "Restarts",
              "color": "#9467bd"
            }
          ]
        ],
        "period": 60,
        "region": "${AWS::Region}",
        "yAxis": {
          "left": {
            "min": 0,
            "label": "Count"
          }
        }
      }
    }
  ]
}
